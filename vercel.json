{
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/registrazione/(.*)",
      "headers": [
        { "key": "Clear-Site-Data", "value": "\"cache\", \"storage\"" }
      ]
    }
  ]
}
